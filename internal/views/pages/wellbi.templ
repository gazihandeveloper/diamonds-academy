package pages

import (
	"github.com/diamondsacademy/diamonds/internal/views/layouts"
)

type WellbiProps struct {
	Theme string
}

templ Wellbi(p WellbiProps) {
	@layouts.Base("Wellbi", p.Theme) {
		<div class="min-h-dynamic bg-gray-50 flex flex-col">
			<!-- Header -->
			<header class="flex items-center justify-between px-4 sm:px-6 py-3 border-b border-gray-200 bg-white shrink-0">
				<a href="/" class="flex items-center gap-3 hover:opacity-80 transition">
					<svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
						<path d="M19 12H5M12 19l-7-7 7-7"/>
					</svg>
					<div class="leading-tight">
						<div class="text-[10px] tracking-[0.2em] text-blue-600 font-bold">DIAMONDS</div>
						<div class="text-[9px] tracking-[0.2em] text-gray-400">ACADEMY</div>
					</div>
				</a>
				<div class="flex items-center gap-2">
					<span class="text-2xl">🤖</span>
					<div>
						<div class="text-gray-900 font-bold text-sm tracking-wider">WELLBI</div>
						<div class="text-[9px] text-blue-600 tracking-[0.2em] font-semibold">AI ASISTAN</div>
					</div>
				</div>
			</header>

			<!-- Messages -->
			<div id="wellbi-messages" class="flex-1 overflow-y-auto px-4 sm:px-6 py-6 space-y-4 overscroll-contain">
				<div class="max-w-3xl mx-auto space-y-4">
					<div class="flex items-start gap-3">
						<div class="w-8 h-8 rounded-full bg-blue-100 flex items-center justify-center shrink-0 text-sm">🤖</div>
						<div class="bg-white border border-gray-200 rounded-2xl rounded-tl-sm px-4 py-3 shadow-sm">
							<p class="text-gray-800 text-sm leading-relaxed">Merhaba! Ben Wellbi, size nasıl yardımcı olabilirim? 🤗</p>
						</div>
					</div>
				</div>
			</div>

			<!-- Input -->
			<div class="shrink-0 border-t border-gray-200 bg-white">
				<div class="max-w-3xl mx-auto w-full px-4 sm:px-6 py-4">
					<div class="flex gap-2">
						<input id="wellbi-input" type="text" placeholder="Mesajınızı yazın..." autocomplete="off"
							class="flex-1 border border-gray-300 rounded-xl px-4 py-3 text-gray-900 text-sm placeholder:text-gray-400 focus:outline-none focus:border-blue-600 focus:ring-2 focus:ring-blue-100 transition min-h-[44px] bg-white"
							onkeydown="if(event.key==='Enter') sendWellbiMsg()"/>
						<button onclick="sendWellbiMsg()" class="w-12 h-12 rounded-xl bg-blue-600 hover:bg-blue-700 transition flex items-center justify-center shrink-0 min-w-[44px] min-h-[44px]">
							<svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
								<path d="M22 2L11 13M22 2l-7 20-4-9-9-4 20-7z"/>
							</svg>
						</button>
					</div>
					<p class="text-center text-[10px] text-gray-400 mt-3 tracking-wide">Bu bilgiler destek amaçlıdır, tıbbi tavsiye niteliği taşımaz.</p>
				</div>
			</div>
		</div>

		<script>
			function resizeWellbi() {
				var msgs = document.getElementById('wellbi-messages');
				if (msgs && window.visualViewport) {
					var header = msgs.previousElementSibling;
					var input = msgs.nextElementSibling;
					var hh = header ? header.offsetHeight : 0;
					var ih = input ? input.offsetHeight : 0;
					msgs.style.height = (window.visualViewport.height - hh - ih) + 'px';
				}
			}
			document.addEventListener('DOMContentLoaded', function() {
				resizeWellbi();
				if (window.visualViewport) {
					window.visualViewport.addEventListener('resize', resizeWellbi);
				}
				var i = document.getElementById('wellbi-input');
				if (i) i.addEventListener('focus', function() { setTimeout(resizeWellbi, 300); });
			});
			function sendWellbiMsg() {
				var input = document.getElementById('wellbi-input');
				var msg = input.value.trim();
				if (!msg) return;
				var msgs = document.getElementById('wellbi-messages');
				var container = msgs.querySelector('.max-w-3xl') || msgs;
				// User message
				var userDiv = document.createElement('div');
				userDiv.className = 'flex items-start gap-3 justify-end';
				userDiv.innerHTML = '<div class="bg-blue-600 text-white rounded-2xl rounded-tr-sm px-4 py-3 max-w-[85%]"><p class="text-sm leading-relaxed">'+escapeHTML(msg)+'</p></div><div class="w-8 h-8 rounded-full bg-blue-600 flex items-center justify-center shrink-0 text-sm text-white font-bold">S</div>';
				container.appendChild(userDiv);
				input.disabled = true;
				input.value = '';
				msgs.scrollTop = msgs.scrollHeight;
				// Loading
				var loadDiv = document.createElement('div');
				loadDiv.id = 'wellbi-loading';
				loadDiv.className = 'flex items-start gap-3';
				loadDiv.innerHTML = '<div class="w-8 h-8 rounded-full bg-blue-100 flex items-center justify-center shrink-0 text-sm">🤖</div><div class="bg-white border border-gray-200 rounded-2xl rounded-tl-sm px-4 py-3 shadow-sm"><p class="text-gray-400 text-sm">Yazıyor...</p></div>';
				container.appendChild(loadDiv);
				msgs.scrollTop = msgs.scrollHeight;
				// API
				fetch('/api/wellbi/chat', {
					method: 'POST',
					headers: {'Content-Type': 'application/json'},
					body: JSON.stringify({message: msg})
				}).then(function(resp) { return resp.json(); }).then(function(data) {
					var ld = document.getElementById('wellbi-loading');
					if (ld) ld.remove();
					var botDiv = document.createElement('div');
					botDiv.className = 'flex items-start gap-3';
					botDiv.innerHTML = '<div class="w-8 h-8 rounded-full bg-blue-100 flex items-center justify-center shrink-0 text-sm">🤖</div><div class="bg-white border border-gray-200 rounded-2xl rounded-tl-sm px-4 py-3 max-w-[85%] shadow-sm"><p class="text-gray-800 text-sm leading-relaxed">'+escapeHTML(data.reply || "Bir yanıt alınamadı.")+'</p></div>';
					container.appendChild(botDiv);
					msgs.scrollTop = msgs.scrollHeight;
				}).catch(function() {
					var ld = document.getElementById('wellbi-loading');
					if (ld) ld.remove();
					var errDiv = document.createElement('div');
					errDiv.className = 'flex items-start gap-3';
					errDiv.innerHTML = '<div class="w-8 h-8 rounded-full bg-blue-100 flex items-center justify-center shrink-0 text-sm">🤖</div><div class="bg-white border border-gray-200 rounded-2xl rounded-tl-sm px-4 py-3 max-w-[85%] shadow-sm"><p class="text-gray-800 text-sm leading-relaxed">Bağlantı hatası oluştu. Lütfen tekrar deneyin.</p></div>';
					container.appendChild(errDiv);
					msgs.scrollTop = msgs.scrollHeight;
				}).finally(function() {
					input.disabled = false;
					input.focus();
				});
			}
			function escapeHTML(str) {
				var div = document.createElement('div');
				div.appendChild(document.createTextNode(str));
				return div.innerHTML;
			}
		</script>
	}
}
